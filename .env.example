# Server Configuration
MCP_SHELL_SERVER_NAME=mcp-shell 🐚
MCP_SHELL_SERVER_VERSION=1.0.0
MCP_SHELL_SPEC_DIR=./specs
MCP_SHELL_STORAGE_ROOT=./storage

# runprompt__generate_artifact prerequisites:
# 1) install runprompt CLI first:
#    uv pip install git+https://github.com/chr15m/runprompt
#    # or: pip install "git+https://github.com/chr15m/runprompt.git"
RUNPROMPT_MODEL=openrouter/deepseek/deepseek-v3.2
BASE_URL=https://openrouter.ai/api/v1
API_KEY=INSERT_YOUR_API_KEY
http_proxy=http://127.0.0.1:8890
HTTP_PROXY=http://127.0.0.1:8890
https_proxy=http://127.0.0.1:8890
HTTPS_PROXY=http://127.0.0.1:8890
